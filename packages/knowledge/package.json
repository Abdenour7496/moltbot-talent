  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "chromadb": "^1.8.0",
    "glob": "^11.0.0",
