{
  "name": "@moltbot-talent/knowledge",
  "version": "0.1.0",
  "description": "RAG pipeline and knowledge management for Moltbot Talent",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ingestion": {
      "import": "./dist/ingestion/index.js",
      "types": "./dist/ingestion/index.d.ts"
    },
    "./vectordb": {
      "import": "./dist/vectordb/index.js",
      "types": "./dist/vectordb/index.d.ts"
    },
    "./retrieval": {
      "import": "./dist/retrieval/index.js",
